<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#F0F4F8">


    <TextView
        android:id="@+id/txtCalorias"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="60sp"
        android:textStyle="bold"
        android:textColor="@color/calories"
        android:layout_gravity="center"
        android:padding="24dp"
        android:shadowColor="#B0BEC5"
        android:shadowRadius="5"
        android:shadowDx="1"
        android:shadowDy="1" />


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:background="#FFFFFF"
        android:elevation="8dp"
        android:layout_marginTop="24dp"
        android:layout_marginHorizontal="16dp">

        <TextView
            android:id="@+id/txtProteinas"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/protein"
            android:padding="12dp"
            android:gravity="center" />

        <TextView
            android:id="@+id/txtGrasas"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/fat"
            android:padding="12dp"
            android:gravity="center" />

        <TextView
            android:id="@+id/txtCarbohidratos"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/carb"
            android:padding="12dp"
            android:gravity="center" />
    </LinearLayout>
</LinearLayout>